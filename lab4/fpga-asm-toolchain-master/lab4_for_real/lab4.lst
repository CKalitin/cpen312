0258            450   ; ============================================================
0258            451   ; Utility: Get 7-seg code for student number digit
0258            452   ; Input: A = index (0-7 maps to digits 7,3,1,7,7,2,7,1)
0258            453   ; Output: A = 7-seg code
0258            454   ; ============================================================
0258            455   get_digit_mod8:
0258 5407       456            anl A, #0x07      ; mod 8
025A            457   get_digit:
025A 04         458            inc A             ; DPTR offset (skip ret)
025B 83         459            movc A, @A+PC
025C 22         460            ret
