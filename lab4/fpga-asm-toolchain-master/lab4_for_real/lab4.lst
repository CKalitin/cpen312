0024 22          62            ret
0025             63   
0025             64   ; Check if SW2-SW0 changed. Returns: sets carry if changed.
0025             65   ; Compares current SW2-SW0 with value in R7.
0025             66   CheckSWChanged:
0025 E5E8        67            mov A, SWA
0027 5407        68            anl A, #0x07
0029 B50702      69            cjne A, 7, sw_changed  ; compare with R7 (register 7)
002C C3          70            clr C
002D 22          71            ret
002E             72   sw_changed:
002E D3          73            setb C
002F 22          74            ret
