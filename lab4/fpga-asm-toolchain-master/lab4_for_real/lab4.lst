0003             35   ; Delay subroutines (33.33MHz clock, 1 cycle = 30ns)
0003             36   ; ============================================================
0003             37   ; ~0.5s delay
0003             38   WaitHalfSec:
0003 7A5A        39            mov R2, #90
0005 79FA        40   L3: mov R1, #250
0007 78FA        41   L2: mov R0, #250
0009 D8FE        42   L1: djnz R0, L1
000B D9FA        43            djnz R1, L2
000D DAF6        44            djnz R2, L3
000F 22          45            ret
0010             46   
0010             47   ; ~1s delay
0010             48   WaitOneSec:
0010 120003      49            lcall WaitHalfSec
0013 120003      50            lcall WaitHalfSec
0016 22          51            ret
0017             52   
0017             53   ; Delay based on SW3: 1s if SW3=0, 0.5s if SW3=1
0017             54   WaitSW3:
0017 E5E8        55            mov A, SWA
0019 5408        56            anl A, #0x08
001B 7004        57            jnz WaitSW3_half
001D 120010      58            lcall WaitOneSec
