0206            391   ; ============================================================
0206            392   ; Case 111: Custom - Knight rider bounce across digits
0206            393   ; Displays single digit bouncing: 7.....  .3....  ..1...  ...7..  ....7.  .....2  ....7.  ...7.. etc.
0206            394   ; ============================================================
0206            395   case_111:
0206 7B00       396            mov R3, #0        ; position 0-5
0208 7C00       397            mov R4, #0        ; direction: 0=right, 1=left
020A            398   case_111_loop:
